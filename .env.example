# Database (SQLite for MVP; for Postgres use postgresql://... and change provider in prisma/schema.prisma)
DATABASE_URL="file:./prisma/dev.db"

# SMTP (optional — if not set, orders/contacts are still saved to DB, user sees "Manager will contact you")
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cenvora.ro

# Recipients for order and contact form emails
ORDER_TO_EMAIL=orders@cenvora.ro
CONTACT_TO_EMAIL=contact@cenvora.ro

# Optional: Google Analytics (only loaded when user accepts Analytics cookies)
NEXT_PUBLIC_GA_ID=

# Optional: company contact display (defaults in config/company.ts)
# NEXT_PUBLIC_COMPANY_EMAIL=contact@cenvora.ro
# NEXT_PUBLIC_COMPANY_PHONE=+40 123 456 789
# NEXT_PUBLIC_MAP_EMBED_URL=
# NEXT_PUBLIC_MAP_LINK=
